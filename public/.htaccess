# ── Block access to sensitive files ──────────────────────────────────────────
<Files "config.local.php">
    Require all denied
</Files>

<Files ".env">
    Require all denied
</Files>

<FilesMatch "\.(git|env|ini|log|bak|sql)$">
    Require all denied
</FilesMatch>

# ── Block directory listing ──────────────────────────────────────────────────
Options -Indexes

# ── Cache control ────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # HTML: never cache (prevents stale SPA shells)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Versioned assets (Vite adds hash to filenames): cache 1 year
  <FilesMatch "\.(js|css|woff2|woff|svg|png|jpg|jpeg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # SEO files: moderate cache
  <FilesMatch "(robots\.txt|sitemap\.xml|manifest\.webmanifest)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# ── Compression (LiteSpeed/Apache) ───────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# ── SPA fallback — serve index.html for client-side routes ───────────────────
RewriteEngine On
RewriteBase /

# If the request is an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, serve index.html (SPA routing)
RewriteRule ^ index.html [L]
